    <style>
        :root {
            --orange: #F58427;
            --white: #FFFFFF;
            --green: #2CAB41;
            --dark: #333333;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background: linear-gradient(to bottom, #FF9933 0%, #FFFFFF 50%, #138808 100%);
            background-attachment: fixed;
            color: var(--dark);
        }
        .top-bar {
            background-color: var(--green);
            color: var(--white);
            padding: 10px 20px;
            text-align: right;
            font-size: 14px;
            font-weight: bold;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.2);
        }
        header {
            background-color: var(--white);
            padding: 30px 20px;
            /* Flexbox use karke logo aur text ko center mein line up kiya hai */
            display: flex;
            align-items: center;
            justify-content: center;
            flex-wrap: wrap; /* Content wrap hone par center mein rahe */
            gap: 15px; /* Logo aur text ke beech ki jagah */
            border-bottom: 5px solid var(--orange);
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
            margin: 20px;
            border-radius: 10px;
        }
        h1 {
            color: var(--orange);
            margin: 0;
            font-size: 40px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }
        .address {
            font-size: 16px;
            color: #555;
            margin: 10px 0;
            /* Header ke flex container se content bahar na jaye, isliye block display kiya */
            display: block; 
            width: 100%;
            text-align: center;
        }
        .tagline {
            color: var(--green);
            font-weight: bold;
            font-size: 18px;
            margin-top: 5px;
            /* Header ke flex container se content bahar na jaye */
            display: block;
            width: 100%;
            text-align: center;
        }
        .container {
            max-width: 1200px;
            margin: 30px auto;
            padding: 0 20px;
        }
        .section-title {
            text-align: center;
            color: var(--dark);
            font-size: 32px;
            margin-bottom: 30px;
            background-color: var(--white);
            display: inline-block;
            padding: 10px 30px;
            border-radius: 30px;
            border: 3px solid var(--orange);
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .text-center {
            text-align: center;
        }
        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
            align-items: start;
        }
        .service-card {
            background-color: var(--white);
            border-top: 5px solid var(--green);
            padding: 25px;
            border-radius: 8px;
            box-shadow: 0 6px 20px rgba(0,0,0,0.15);
            transition: transform 0.3s ease;
        }
        .service-card:hover {
            transform: translateY(-5px);
            border-top: 5px solid var(--orange);
        }
        .service-card h3 {
            color: var(--orange);
            margin-top: 0;
            border-bottom: 1px solid #eee;
            padding-bottom: 12px;
            font-size: 20px;
        }
        .service-card ul {
            list-style-type: none;
            padding: 0;
            margin: 0;
        }
        
        /* WHATSAPP CLICK EFFECT CSS */
        .service-card li {
            padding: 0; 
            margin-bottom: 6px;
            font-size: 15px;
            border-bottom: none;
            cursor: pointer; 
            transition: color 0.2s ease;
        }
        .service-card li:hover {
            color: var(--orange); 
            text-decoration: underline;
        }
        
        .service-card li::before {
            content: "✔ ";
            color: var(--green);
            font-weight: bold;
            margin-right: 5px;
            text-decoration: none;
            display: inline-block;
        }
        
        .photo-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 5px;
            width: 130px; 
        }
        .photo-grid img {
            width: 100%;
            height: 60px; 
            object-fit: cover;
            border-radius: 4px;
            border: 1px solid #ccc;
        }
        /* Yahan Photoshop photo ki height 250px hi rakhi gayi hai */
        .photo-grid img:first-child {
            grid-column: span 2; 
            height: 250px; 
        }

        footer {
            background-color: var(--dark);
            color: var(--white);
            text-align: center;
            padding: 30px 20px;
            margin-top: 50px;
            border-top: 5px solid var(--orange);
        }
        footer h3 {
            color: var(--white);
            margin-bottom: 10px;
        }
        .contact-btn {
            background-color: var(--green);
            color: var(--white);
            padding: 12px 25px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: bold;
            display: inline-block;
            margin-top: 15px;
            transition: background-color 0.3s ease;
        }
        .contact-btn:hover {
            background-color: var(--orange);
        }
    </style>
</head>
