    <script>
        // Aapka WhatsApp Number
        const waNumber = "919085191973"; 

        // Website par jitne bhi 'li' (services ke text) hain, sabko select karo
        const allServices = document.querySelectorAll('.service-card li');

        allServices.forEach(function(item) {
            item.addEventListener('click', function() {
                
                // Click kiye gaye service ka naam uthao (e.g., "Aadhar Correction")
                let serviceName = this.innerText.trim();
                
                // Uske box ka heading uthao (e.g., "1. AADHAR CARD")
                let categoryElement = this.closest('.service-card').querySelector('h3');
                let categoryName = categoryElement ? categoryElement.innerText.trim() : "Service";
                
                // 3 Languages mein message generate karo
                let textMessage = "Hello R.K. Communication,\n\n" +
                                  "🇬🇧 English: I need *" + serviceName + "* service from *" + categoryName + "*.\n" +
                                  "🇮🇳 Hindi: Mujhe *" + categoryName + "* ka *" + serviceName + "* service chahiye.\n" +
                                  "🇦🇸 Assamese: Mok *" + categoryName + "* or *" + serviceName + "* sewa lage.";
                
                // WhatsApp ka link open karo naye tab mein
                let autoMessage = encodeURIComponent(textMessage);
                let waLink = "https://wa.me/" + waNumber + "?text=" + autoMessage;
                window.open(waLink, '_blank');
            });
        });
    </script>

